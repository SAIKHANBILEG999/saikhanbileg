rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /scores/{document} {
      allow read: if true;
      allow create: if request.resource.data.score is number
                    && request.resource.data.name is string
                    && request.resource.data.mode is string;
      allow update, delete: if false;
    }

    match /typeracer_rooms/{roomId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
                    && request.resource.data.status == "waiting"
                    && request.resource.data.players is map;
      allow update: if request.resource.data.status in ["waiting", "countdown", "playing", "finished"]
                    && request.resource.data.players is map;
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.rating is number
                    && request.resource.data.movieTitle is string
                    && request.resource.data.reviewText is string;
      allow update, delete: if false;
    }
  }
}
